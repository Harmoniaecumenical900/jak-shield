{
  "name": "@jak-shield/gemini",
  "version": "0.1.0",
  "description": "JAK Shield adapter for Google Gemini. Wraps shield tools as Gemini FunctionDeclarations and provides a function-call dispatcher.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@google/genai": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "gemini",
    "google-ai",
    "ai-safety",
    "prompt-injection",
    "agent-security",
    "jak-shield"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inbharatai/jak-shield.git",
    "directory": "packages/adapters/gemini"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": {
    "name": "JAK Shield",
    "email": "hello@jakshield.ai"
  },
  "bugs": {
    "url": "https://github.com/inbharatai/jak-shield/issues"
  },
  "homepage": "https://github.com/inbharatai/jak-shield#readme",
  "engines": {
    "node": ">=20.0.0"
  }
}
