# JAK Shield environment variables

# === Core ===

# Database (Postgres for SaaS; omit for in-memory dev mode w/o auth)
DATABASE_URL=postgresql://jakshield:jakshield@localhost:5432/jak_shield

# AES-256-GCM master key for encrypted credentials & at-rest data (64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JAK_SHIELD_FIELD_KEY=

# Auth secrets — both should be ≥32 random chars in production
JAK_SHIELD_JWT_SECRET=dev-jwt-secret-change-me
JAK_SHIELD_COOKIE_SECRET=dev-cookie-secret-change-me
JAK_SHIELD_JWT_TTL_SECONDS=43200       # 12h
JAK_SHIELD_BCRYPT_ROUNDS=10
JAK_SHIELD_INVITE_TTL_HOURS=72

# === OpenAI risk classifier (optional — system degrades gracefully) ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_TIMEOUT_MS=1500
SHIELD_CLASSIFIER_CACHE_TTL_MS=60000

# === Service ports / hosts ===
SHIELD_API_PORT=4100
SHIELD_API_HOST=0.0.0.0
SHIELD_MCP_HTTP_PORT=4101
SHIELD_MCP_HTTP_HOST=0.0.0.0
SHIELD_DASHBOARD_URL=http://localhost:3000

# === MCP HTTP gateway auth ===
# 1 (default) = require API key on every request. Set to 0 only for sandbox dev.
SHIELD_MCP_REQUIRE_AUTH=1

# === Local-mode fallback ===
# When SHIELD_AUTH_OPTIONAL=1 the API allows requests with no auth and uses
# the SHIELD_DEFAULT_* vars for context. Useful for stdio MCP clients only.
SHIELD_AUTH_OPTIONAL=0
SHIELD_DEFAULT_TENANT_ID=local
SHIELD_DEFAULT_USER_ID=local-user
SHIELD_DEFAULT_USER_ROLE=TENANT_ADMIN

# === Policy tuning ===
SHIELD_CORPORATE_DOMAINS=jakshield.ai
SHIELD_FS_SANDBOX_ROOT=
SHIELD_SHELL_ALLOWLIST=echo,ls,cat,pwd,whoami,hostname,date,uptime,df,du,uname
SHIELD_SHELL_TIMEOUT_MS=10000
SHIELD_BROWSER_DENYLIST=
SHIELD_BROWSER_TIMEOUT_MS=8000
SHIELD_BROWSER_MAX_BYTES=200000
SHIELD_HTTP_TIMEOUT_MS=8000

# === Approvals ===
SHIELD_APPROVAL_TTL_SEC=86400          # 24h

# === Connector credentials (per-tenant, also configurable via dashboard UI) ===
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GDRIVE_REFRESH_TOKEN=
GITHUB_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
PG_QUERY_URL=
SLACK_BOT_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# === Logging ===
LOG_LEVEL=info
